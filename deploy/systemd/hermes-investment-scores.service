[Service]
Type=oneshot
User=jianjustin
Group=jianjustin
WorkingDirectory=/opt/hermes-investment-assistant/app
EnvironmentFile=/opt/hermes-investment-assistant/.env
ExecStart=/opt/hermes-investment-assistant/.venv/bin/python -m investment_assistant.tasks.nightly_scores
